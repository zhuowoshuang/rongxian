# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@db:5432/stock_agent
# 本地 SQLite 示例：DATABASE_URL=sqlite:///./stock_agent.db
# 后续 MySQL 迁移示例：DATABASE_URL=mysql+pymysql://user:password@host:3306/qingshu

# Redis（可选）
REDIS_URL=redis://redis:6379/0

# 数据源 API Key（后续接入真实数据时填写）
TUSHARE_TOKEN=
FUTU_ACCESS_TOKEN=

# 调试模式
APP_ENV=development
DEBUG=false

# 超级管理员初始化（生产环境必须显式配置强密码）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# --- Quota defaults ---
# Admin users are exempt from runtime action quotas.
DEFAULT_DAILY_REPORT_LIMIT=20
DEFAULT_DAILY_PDF_LIMIT=30
DEFAULT_DAILY_PNG_LIMIT=30
DEFAULT_DAILY_BACKTEST_LIMIT=20
DEFAULT_DAILY_HTML_VIEW_LIMIT=1000
DEFAULT_MAX_API_CONFIGS=5

# --- Redis production note ---
# Redis is optional for local demo. If REDIS_URL is unset/unavailable, cache,
# async jobs and queue-like capabilities are degraded. Production should enable it.
REDIS_URL=redis://redis:6379/0

# --- MySQL production migration preparation ---
# Example only, never commit real passwords:
# DATABASE_URL=mysql+pymysql://qingshu_user:CHANGE_ME@mysql-host:3306/qingshu?charset=utf8mb4
# Dependency: pymysql is listed in backend/requirements.txt. Add aiomysql later only
# if the backend is migrated to async SQLAlchemy.
# Suggested steps: back up SQLite first, create an empty MySQL database, set
# DATABASE_URL, start the backend to create tables, then import validated data.
# For production, introduce Alembic migrations before schema changes.
# Backup: keep regular MySQL backups for users, api configs, report_events,
# backtest_tasks and operation_logs.
